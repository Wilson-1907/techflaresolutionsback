# TechFlare Unified Backend — full environment reference
# Render: use exact key names (case-sensitive for Database_name, DB_user, etc.)

# ── Database (Aiven PostgreSQL) ─────────────────────────────────────────────
Database_name=defaultdb
DB_user=avnadmin
DB_password=YOUR_AIVEN_PASSWORD
DB_HOST=pg-xxxx.a.aivencloud.com
DB_port=16638
DATABASE_URL=postgresql://avnadmin:YOUR_AIVEN_PASSWORD@pg-xxxx.a.aivencloud.com:16638/defaultdb?sslmode=require

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
SEED_DEMO_DATA=false

# ── Auth & panel API keys ─────────────────────────────────────────────────────
JWT_SECRET=long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
ADMIN_API_KEY=your-admin-api-key
FINANCE_API_KEY=TechFlare@FinanceApi2026
ADMIN_PANEL_PASSWORD=TechFlare@Admin2026!
FINANCE_PANEL_PASSWORD=TechFlare@Finance2026!
ENCRYPTION_KEY=64-char-hex-from-openssl-rand-hex-32

# ── URLs & CORS (comma-separated, no spaces) ──────────────────────────────────
CORS_ORIGINS=https://techflare-solutions.com,https://www.techflare-solutions.com,https://techflaresolutionss.vercel.app,https://techflaresolutionsadmin-7dyu.vercel.app,https://techflaresolutionsfinance.vercel.app
NEXT_PUBLIC_APP_URL=https://techflare-solutions.com
NEXT_PUBLIC_ADMIN_PANEL_URL=https://techflaresolutionsadmin-7dyu.vercel.app
NEXT_PUBLIC_FINANCE_PANEL_URL=https://techflaresolutionsfinance.vercel.app

# ── Email (Render free tier blocks Gmail SMTP — use Resend or Brevo) ─────────
# Option A — Resend: verify techflare-solutions.com at resend.com/domains, then:
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=TechFlare Solutions <noreply@techflare-solutions.com>
RESEND_REPLY_TO=stechflare@gmail.com

# Option B — Brevo: https://app.brevo.com → SMTP & API → verify sender stechflare@gmail.com
# BREVO_API_KEY=xkeysib-xxxxxxxx
# BREVO_SENDER_EMAIL=stechflare@gmail.com

# Option C — Gmail SMTP (works locally; blocked on Render free tier unless paid instance)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=stechflare@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=TechFlare Solutions <stechflare@gmail.com>

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_FULL_ID.apps.googleusercontent.com

# ── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_SERVICE_URL=

# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
MPESA_PUBLIC_BASE_URL=https://techflaresolutionsback.onrender.com
MPESA_SHORTCODE=9356451
MPESA_TILL_NUMBER=9356451
MPESA_TILL_NAME=TechFlare Solutions
MPESA_CALLBACK_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/callback
MPESA_C2B_CONFIRMATION_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/c2b/confirmation
MPESA_C2B_VALIDATION_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/c2b/validation
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
