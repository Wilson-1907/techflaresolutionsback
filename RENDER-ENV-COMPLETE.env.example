# =============================================================================
# TechFlare Backend — COMPLETE Render environment variables
# Copy each Key/Value pair into Render → techflaresolutionsback → Environment
# =============================================================================
#
# KEYS YOU ALREADY HAVE ON RENDER — keep your existing secret values:
#   ADMIN_API_KEY, AI_SERVICE_URL, CORS_ORIGINS, Database_name, DATABASE_URL,
#   DB_HOST, DB_password, DB_port, DB_user, FINANCE_API_KEY, GOOGLE_CLIENT_ID,
#   GROQ_API_KEY, GROQ_MODEL, JWT_EXPIRES_IN, JWT_SECRET, MPESA_*,
#   NEXT_PUBLIC_APP_URL, NODE_ENV, OPENAI_*, SEED_DEMO_DATA, SMTP_*
#
# ADD THESE (were missing):
#   ADMIN_PANEL_PASSWORD, FINANCE_PANEL_PASSWORD, ENCRYPTION_KEY
#
# REMOVE (not used by backend):
#   SSL_mode
#
# =============================================================================

# --- Database (Aiven) — exact key names, case-sensitive ---
Database_name=defaultdb
DB_user=avnadmin
DB_password=YOUR_AIVEN_PASSWORD
DB_HOST=YOUR_AIVEN_HOST.a.aivencloud.com
DB_port=16638
DATABASE_URL=postgresql://avnadmin:YOUR_AIVEN_PASSWORD@YOUR_AIVEN_HOST.a.aivencloud.com:16638/defaultdb?sslmode=require

# --- Core app ---
NODE_ENV=production
SEED_DEMO_DATA=false

# --- Auth & API keys (must match Vercel admin + finance panels) ---
JWT_SECRET=YOUR_JWT_SECRET_OR_KEEP_EXISTING
JWT_EXPIRES_IN=7d
ADMIN_API_KEY=YOUR_ADMIN_API_KEY_OR_KEEP_EXISTING
FINANCE_API_KEY=TechFlare@FinanceApi2026

# --- Panel login passwords (ADD THESE — match Vercel admin/finance) ---
ADMIN_PANEL_PASSWORD=TechFlare@Admin2026!
FINANCE_PANEL_PASSWORD=TechFlare@Finance2026!

# --- Field encryption (ADD THIS — 64 hex chars) ---
ENCRYPTION_KEY=11213d47f6d2577f8615fd150a6a4658cf7a030470aeb365b3a6e2444724def9b27772cbadc981160db057ce8b98ac468ff16ba60868a372ca896ef74a798d17

# --- CORS & URLs (no spaces after commas) ---
CORS_ORIGINS=https://techflaresolutionss.vercel.app,https://techflaresolutionsadmin-7dyu.vercel.app,https://techflaresolutionsfinance.vercel.app
NEXT_PUBLIC_APP_URL=https://techflaresolutionss.vercel.app
NEXT_PUBLIC_ADMIN_PANEL_URL=https://techflaresolutionsadmin-7dyu.vercel.app
NEXT_PUBLIC_FINANCE_PANEL_URL=https://techflaresolutionsfinance.vercel.app

# --- Email — Resend (required on Render free tier) ---
# Step 1: resend.com/domains → add techflare-solutions.com → copy DNS records to Cloudflare
# Step 2: Wait until Resend shows domain Verified
# Step 3: Set RESEND_FROM to your domain (NOT onboarding@resend.dev)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM=TechFlare Solutions <noreply@techflare-solutions.com>
RESEND_REPLY_TO=stechflare@gmail.com

# Gmail SMTP only works on paid Render instances (optional fallback):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=stechflare@gmail.com
# SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
# SMTP_FROM=TechFlare Solutions <stechflare@gmail.com>

# --- Google Sign-In (full client ID required) ---
GOOGLE_CLIENT_ID=YOUR_FULL_ID.apps.googleusercontent.com

# --- AI chatbot ---
GROQ_API_KEY=YOUR_GROQ_KEY
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_SERVICE_URL=

# --- M-Pesa (Daraja production) ---
MPESA_PUBLIC_BASE_URL=https://techflaresolutionsback.onrender.com
MPESA_SHORTCODE=9356451
MPESA_TILL_NUMBER=9356451
MPESA_TILL_NAME=TechFlare Solutions
MPESA_CALLBACK_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/callback
MPESA_C2B_CONFIRMATION_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/c2b/confirmation
MPESA_C2B_VALIDATION_URL=https://techflaresolutionsback.onrender.com/api/payments/mpesa/c2b/validation
MPESA_CONSUMER_KEY=YOUR_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_MPESA_CONSUMER_SECRET
MPESA_PASSKEY=YOUR_MPESA_PASSKEY
